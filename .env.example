# --- Google Gemini (chat features) ---
# Used by /api/explain and /api/mentor.
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Optional: override the model (defaults to gemini-2.5-flash).
# GEMINI_MODEL=gemini-2.5-flash

# --- Supabase (auth + database) ---
# Create a free project at https://supabase.com.
# Project Settings → API gives you the URL and the *anon* (public) key.
# Then run supabase/schema.sql in the SQL editor to create tables + RLS policies.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
